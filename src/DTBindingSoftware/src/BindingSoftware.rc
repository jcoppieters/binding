IDR_CONTEXTMENU_NODE MENU
BEGIN
    POPUP "Contextmenu node"
    BEGIN
        MENUITEM "Show properties",             ID_CONTEXTMENUNODE_SHOWPROPERTIES
        MENUITEM "Show control",                ID_CONTEXTMENUNODE_SHOWCONTROL
        MENUITEM "Show screenmapping",          ID_CONTEXTMENUNODE_SHOWSCREENMAPPING
        MENUITEM "Show configuration",          ID_CONTEXTMENUNODE_SHOWCONFIGURATION
        MENUITEM "Show master tasks",           32907, INACTIVE
        MENUITEM "Show LAN UDP configuration.", 32911, INACTIVE
        MENUITEM SEPARATOR
        MENUITEM "Rename",                      ID_CONTEXTMENUNODE_RENAME
        MENUITEM SEPARATOR
        MENUITEM "Browse node (Check for new units)", ID_CONTEXTMENUNODE_BROWSE
    END
END

IDR_CONTEXTMENU_TREEUNITS MENU
BEGIN
    POPUP "TreeUnits"
    BEGIN
        MENUITEM "Show unit properties",        ID_TREEUNITS_SHOWUNITPROPERTIES
        MENUITEM "Rename unit",                 ID_TREEUNITS_RENAMEUNIT
    END
END

IDR_CONTEXTMENU_TREENODE MENU
BEGIN
    POPUP "Contextmenu node"
    BEGIN
        MENUITEM "Show properties",             ID_CONTEXTMENUNODE_SHOWPROPERTIES
        MENUITEM "Show control",                ID_CONTEXTMENUNODE_SHOWCONTROL
        MENUITEM "Show screenmapping",          ID_CONTEXTMENUNODE_SHOWSCREENMAPPING
        MENUITEM "Show configuration",          ID_CONTEXTMENUNODE_SHOWCONFIGURATION
        MENUITEM "Show master tasks",           ID_CONTEXTMENUNODE_SHOWMASTERTASKS, INACTIVE
        MENUITEM "Show LAN UDP configuration",  ID_CONTEXTMENUNODE_SHOWLANCFG, INACTIVE
        MENUITEM SEPARATOR
        MENUITEM "Rename",                      ID_CONTEXTMENUNODE_RENAME
        MENUITEM SEPARATOR
        MENUITEM "Browse node (Check for new units)", ID_CONTEXTMENUNODE_BROWSE
    END
END

IDR_CONTEXTMENU_TREENODEBINDINGS MENU
BEGIN
    POPUP "Tree node bindings"
    BEGIN
        MENUITEM "View binding",                ID_TREENODEBINDINGS_VIEWBINDING
        MENUITEM SEPARATOR
        MENUITEM "Rename binding",              ID_TREENODEBINDINGS_RENAMEBINDING
    END
END

IDR_CONTEXTMENU_VIEWUNITS MENU
BEGIN
    POPUP "TreeUnits"
    BEGIN
        MENUITEM "Show unit properties",        ID_VIEWUNITS_SHOWUNITPROPERTIES
        MENUITEM "Rename unit",                 ID_VIEWUNITS_RENAMEUNIT
    END
END

IDR_CONTEXTMENU_TREEBINDINGS MENU
