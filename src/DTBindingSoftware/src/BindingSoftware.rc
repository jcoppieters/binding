IDR_MAINFRAME_INSTALLATION MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "&Export File",                ID_FILE_EXPORT
        MENUITEM SEPARATOR
        MENUITEM "&Print...\tCtrl+P",           ID_FILE_PRINT, GRAYED
        MENUITEM "Print Pre&view",              ID_FILE_PRINT_PREVIEW, GRAYED
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "View &Bindings worksheet",    ID_BUTTON_VIEW_BINDINGS
        MENUITEM "View &Node List",             ID_BUTTON_VIEW_NODES
        MENUITEM "View &Units ",                ID_BUTTON_VIEW_UNITS
        MENUITEM "View Units extended properties", ID_VIEW_UNIT_EXT_PROP
        MENUITEM SEPARATOR
        POPUP "Display bindings in TreeView"
        BEGIN
            MENUITEM "Sort Bindings",               ID_VIEW_SORT_BINDINGS
            MENUITEM "&Show bindings only by name", ID_TREEVIEW_BINDINGS_ONLYNAME
            MENUITEM "Show Bindings by &name and number", ID_TREEVIEW_BINDINGS_NAMEANDNUMBER
            MENUITEM "Show bindings by n&unmber and name", ID_TREEVIEW_BINDINGS_NUMBERANDNAME
        END
        POPUP "Display Nodes in TreeView"
        BEGIN
            MENUITEM "Show nodes only by &name",    ID_VIEW_SORTNODESONLYNAME
            MENUITEM "&Show Nodes by name and address", ID_VIEW_SORTNODESBYNAME
            MENUITEM "Show Nodes by &Logical Address", ID_VIEW_SORTNODESBYLOGICALADDRESS
            MENUITEM "Show Nodes by &physical Address", ID_VIEW_SORTNODESBYPHADDRESS
        END
        POPUP "Display Units in treeView"
        BEGIN
            MENUITEM "&Show Units by name",         ID_VIEW_UNITSBYNAME
            MENUITEM "Show units only by &name",    ID_VIEW_UNITSONLYNAME
            MENUITEM "Show Units by &Address",      ID_VIEW_UNITSBYADDRESS
        END
        MENUITEM SEPARATOR
        POPUP "View &Mode"
        BEGIN
            MENUITEM "Beginner",                    ID_VIEW_MODE_SIMPLE, CHECKED
            MENUITEM "Intermediate",                ID_VIEW_MODE_NORMAL, CHECKED
            MENUITEM "Expert",                      ID_VIEW_MODE_ADVANCED, CHECKED
        END
        MENUITEM "Software update &options",    IDR_VIEW_OPTIONS_SOFTWAREUPDATE
        MENUITEM SEPARATOR
        MENUITEM "View &IR code list",          32887
        MENUITEM "&Energy management config",   ID_VIEW_ENERGYMANAGEMENTCONFIG
        MENUITEM "DALI bus config",             32921
    END
    POPUP "&Network"
    BEGIN
        MENUITEM "&Set ComPort",                ID_BUTTON_SET_COMPORT
        MENUITEM SEPARATOR
        MENUITEM "&Connect",                    ID_BUTTON_CONNECT
        MENUITEM "&DisConnect",                 ID_BUTTON_DISCONNECT
        MENUITEM SEPARATOR
        MENUITEM "&Send Programmation File",    ID_BUTTON_BINDINGS_SENDALL
        MENUITEM "Send &Modified Bindings",     ID_BUTTON_BINDINGS_SENDMODIFIED
        MENUITEM SEPARATOR
        MENUITEM "&Read Bindings",              ID_BUTTON_BINDINGS_READ
        MENUITEM SEPARATOR
        MENUITEM "Communication &Tracer",       ID_BUTTON_TRACER
        MENUITEM "Modem Status",                ID_MODEMSTATUS
        MENUITEM "&Network Status",             ID_NETWORK_STATUS
        MENUITEM SEPARATOR
        MENUITEM "LAN network devices",         ID_NETWORK_LAN_DEVICES
        MENUITEM "LAN network settings",        32912
        MENUITEM SEPARATOR
        MENUITEM "Engineer configuration mode", ID_CONFIGURATION
        MENUITEM "Engineer message transfer",   ID_NETWORK_MESSAGETRANSFER
        MENUITEM "Engineer CAN FTP",            ID_NETWORK_CANFTP
        MENUITEM "Engineer CAN logger",         ID_NETWORK_ENGINEERCANLOGGER
    END
    POPUP "Auto binding &Options"
    BEGIN
        POPUP "&Dimmers"
        BEGIN
            MENUITEM "On Off + Dim up/Dn",          ID_DIMMERS_ONOFF, CHECKED
            MENUITEM "PIR Timed On",                ID_DIMMERS_PIRTIMED, CHECKED
        END
        POPUP "Relais"
        BEGIN
            MENUITEM "Switch On/Off",               ID_RELAIS_ONOFF, CHECKED
            MENUITEM "PIR Timed on",                ID_RELAIS_PIRTIMEDON, CHECKED
        END
        POPUP "Sens"
        BEGIN
            MENUITEM "Set &Heating as default",     ID_SENS_HEATING, CHECKED
            MENUITEM "Set &Cooling as Default",     ID_SENS_COOLING
        END
        POPUP "Moods"
        BEGIN
            MENUITEM "Set Short Event as default",  ID_MOODS_SHORT
            MENUITEM "Set Long Event as default",   ID_MOODS_LONG
        END
        POPUP "Audio/Video Room"
        BEGIN
            MENUITEM "Audio On/Off + Vol up/down",  32890
            MENUITEM "Audio On/Source Inc/Off + Vol up/down", 32891
        END
        MENUITEM SEPARATOR
        MENUITEM "&Enable Auto bindng",         ID_AUTOBINDING_ENABLE, CHECKED
        MENUITEM SEPARATOR
        MENUITEM "Add auto binding\tF1",        ID_AUTOBINDING_ADD
    END
    POPUP "&Tools_old"
    BEGIN
        MENUITEM "Multimedia Config.",          ID_MULTIMEDIA
        MENUITEM "Request Can Network status",  ID_TOOLS_NICMEDIUM
        MENUITEM "Open &configurator",          ID_TOOLS_CONFIGURATOR
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "Remote config",               ID_TOOLS_REMOTECONFIG
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About Duotecno Binding Software ...", ID_APP_ABOUT
        MENUITEM SEPARATOR
        MENUITEM "Manual &Binding examples",    ID_HELP_BINDINGEXAMPLES
        MENUITEM "Manual &Hardware",            32916
        MENUITEM "Manual Software part&1",      32917
        MENUITEM "Manual Software part&2",      32918
        MENUITEM "Manual software &Expert",     ID_HELP_MANUALSOFTWAREEXPERT
        MENUITEM SEPARATOR
        MENUITEM "&Modbus sensor functions",    32888
        MENUITEM SEPARATOR
        MENUITEM "&Software updates and extra packages", 32910
    END
    POPUP "Debug"
    BEGIN
        MENUITEM "Debug Binding Conversion",    ID_DEBUG_BINDINGCONVERSION
        MENUITEM "Read All bindings",           ID_READALLBINDINGS
        MENUITEM "Debug Conversion from nodes", ID_DEBUG_CONVERSIONFROMNODES
        MENUITEM "Debug Show Task Dialog",      ID_DEBUG_SHOW_TASKDIALOG
        MENUITEM "Debug1",                      ID_DEBUG_GENERAL
    END
END

