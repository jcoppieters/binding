IDD_ABOUTBOX DIALOGEX 0, 0, 273, 74
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Duotecno Binding Software"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,17,20,20
    LTEXT           "Duotecno binding software ",IDC_STATIC,41,16,166,8,SS_NOPREFIX
    LTEXT           "Copyright (C) Duotecno 2004 - 2025",IDC_STATIC,41,47,169,8
    DEFPUSHBUTTON   "OK",IDOK,216,7,50,14,WS_GROUP
    LTEXT           "software version ...",IDC_STATIC_SWVERSION,41,27,131,8
END

