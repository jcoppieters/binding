{
  "name": "duotecno-config-reader",
  "version": "1.0.0",
  "description": "TypeScript reader/writer for Duotecno binding configuration files",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "server": "tsx watch src/server.ts",
    "server:debug": "tsx src/server.ts",
    "test:upload": "tsx src/test-upload.ts",
    "reset": "tsx src/reset-master-state.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "duotecno",
    "home-automation",
    "bindings"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "node-html-parser": "^8.0.4",
    "pdf-parse": "^1.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "ws": "^8.21.1"
  }
}
